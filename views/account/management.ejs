<main>
    <h1>
        <%= title %>
    </h1>

    <!-- Flash message -->
    <%- messages() %>

            <!-- Errors -->
    <% if (errors && errors.length> 0) { %>
        <ul class="error-list">
            <% errors.forEach(error=> { %>
                <li>
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

    <section class="account-management">
        <h2>
            Welcome <%= accountData.account_firstname %>
        </h2>
        <p>Use the links below to manage your account and inventory.</p>
        <!-- CLIENT ONLY -->
        <% if (accountData.account_type==="Client" ) { %>
        
            <p>
                <a href="/account/update/">
                    Update Account Information
                </a>
            </p>
        
            <% } %>
        <!-- EMPLOYEE + ADMIN ONLY -->
        <% if (accountData.account_type==="Employee" || accountData.account_type==="Admin" ) { %>
        
            <!-- update account link (still required for all, so placed ABOVE inventory section) -->
            <p>
                <a href="/account/update/">
                    Update Account Information
                </a>
            </p>
        
            <h3>Inventory Management</h3>
        
            <p>
                <a href="/inv/">
                    Go to Inventory Management
                </a>
            </p>
        
            <% } %>
    </section>
    
</main>