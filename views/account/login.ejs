
<h1>
    <%= title %>
</h1>

<!-- Flash messages -->
<%- messages() %>

    <!-- Validation errors -->
    <% if (errors && !errors.isEmpty()) { %>
        <ul class="notice">
            <% errors.array().forEach(error=> { %>
                <li>
                    <%= error.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

<form class="login" action="/account/login" method="post">
    <label for="email">Email:</label>
    <input type="email" id="email" name="account_email" required>
    <label for="password">Password:</label>
    <input type="password" id="password" name="account_password" required>
    <button type="submit">Login</button>
    <p>No account? <a href="/account/register">Sign up</a>.</p>
</form>